# StockDesk Pro — Firebase configuration
# Copy this file to `.env.local` and fill with your live Firebase project values.
# When all six are set to real values, the app uses Firestore + Firebase Auth.
# If any are missing/placeholder, the app safely runs in in-memory Demo Mode.
#
#   cp .env.example .env.local
#
# Find these in Firebase Console → Project Settings → General → Your apps → SDK setup.
# NOTE: these are client-side public config values, NOT secrets. The real
# security boundary is Firestore Rules. Never commit a service-account key.

VITE_FB_API_KEY=your-api-key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_STORAGE_BUCKET=your-project.appspot.com
VITE_FB_MSG_SENDER_ID=your-sender-id
VITE_FB_APP_ID=your-app-id
